{
  "realm": "clinic-appointment",
  "enabled": true,
  "registrationAllowed": false,
  "roles": {
    "realm": [
      { "name": "ADMIN", "description": "System administrator" },
      { "name": "DOCTOR", "description": "Doctor user" },
      { "name": "PATIENT", "description": "Patient user" }
    ]
  },
  "clients": [
    {
      "clientId": "clinic-web",
      "name": "Clinic Web Client",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": ["http://localhost:3000/*", "http://localhost:8080/*"],
      "webOrigins": ["*"]
    },
    {
      "clientId": "clinic-user-service",
      "name": "Clinic User Service Admin Client",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "secret": "change-me",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false
    }
  ],
  "users": [
    {
      "username": "admin@clinic.local",
      "email": "admin@clinic.local",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        { "type": "password", "value": "admin123", "temporary": false }
      ],
      "realmRoles": ["ADMIN"]
    },
    {
      "username": "service-account-clinic-user-service",
      "enabled": true,
      "serviceAccountClientId": "clinic-user-service",
      "clientRoles": {
        "realm-management": [
          "manage-users",
          "view-users",
          "view-realm"
        ]
      }
    }
  ]
}
